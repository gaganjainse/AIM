FLASK_SECRET=change-me-to-a-random-64-char-string
DB_HOST=localhost
# Docker Compose overrides DB_HOST to db for the app container.
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=attendance_db
DB_POOL_SIZE=5

# Optional email settings (Gmail app password recommended)
EMAIL_USER=
EMAIL_PASS=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_TLS=true

# Session settings
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=aim_session
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
MAX_CONTENT_LENGTH_MB=10
TRUST_PROXY_COUNT=1

# Rate limiting
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per day, 50 per hour

# Caching (use Redis in production)
CACHE_TYPE=SimpleCache
CACHE_REDIS_URL=
CACHE_DEFAULT_TIMEOUT=300

# CORS (comma-separated origins for API)
CORS_ORIGINS=

# Argon2id password hashing
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# Backup encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
BACKUP_ENCRYPTION_KEY=

# Metrics
METRICS_ENABLED=true

# Optional backup / client binary overrides
MYSQL_BIN=mysql
MYSQLDUMP_BIN=mysqldump
